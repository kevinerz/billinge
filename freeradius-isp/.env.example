# Copy this file to .env AT THE REPO ROOT on the Ubuntu VM (wherever you
# clone/copy this project to, e.g. /opt/freeradius-isp) and fill in real
# values. Never commit the real file — keep it out of git, mode 0640 owned
# by root:freerad. scripts/install_ubuntu.sh points systemd's
# EnvironmentFile at this same .env, so FreeRADIUS itself and every
# scripts/*.sh CLI tool read values from one single file — no second copy
# to keep in sync.
#
# Deployment: FreeRADIUS installs directly on an Ubuntu 24.04 VM (no
# Docker). MySQL runs on a SEPARATE server — every scripts/*.sh tool and
# FreeRADIUS itself connect to it over the network via MYSQL_HOST, not
# localhost. That separate MySQL server must already allow TCP connections
# from this VM's IP (MySQL's default is often localhost-only) — that's
# configured on the MySQL server itself, outside anything these scripts do.

MYSQL_HOST=203.0.113.50
MYSQL_PORT=3306
MYSQL_DATABASE=radius

# Full-access admin account — used by scripts/bootstrap_db.sh and every
# other scripts/*.sh CLI tool (add_tenant, add_nas, cleanup_stale_sessions,
# ...), and by any future dashboard/API. Needs broad read/write across the
# whole schema, including billing and user tables.
MYSQL_USER=radius
MYSQL_PASSWORD=change-me

# Used ONLY by scripts/provision_db_users.sh to create RADIUS_DB_USER (see
# below) — never by the running application. On a separate MySQL server you
# don't administer yourself, this may need to be a dedicated admin account
# with GRANT privileges (not necessarily literal `root`) that the DB
# operator has allowed to connect from this VM's IP specifically, rather
# than opening root up broadly.
MYSQL_ADMIN_USER=root
MYSQL_ROOT_PASSWORD=change-me-too

# Restricted account for the FreeRADIUS process itself — see
# scripts/provision_db_users.sh. Deliberately CANNOT read/write
# platform_payments, subscriber_payments, users, audit_logs, or any other
# billing/admin table: FreeRADIUS has no business touching them, so if the
# FreeRADIUS process or its config is ever compromised, the blast radius
# stops at RADIUS-core tables instead of the entire billing/user database.
RADIUS_DB_USER=radius_svc
RADIUS_DB_PASSWORD=change-me-too-please

# This VM's own IP/hostname, as seen BY the MySQL server (not 127.0.0.1 —
# they're different machines now). scripts/provision_db_users.sh scopes
# RADIUS_DB_USER's grants to this exact host rather than '%' (any host) —
# with MySQL on a real separate server reachable over the network, '%'
# would let that account authenticate from anywhere that has the password,
# not just this VM.
RADIUS_VM_IP=203.0.113.10

# Fallback shared secret for the static `client localhost` entry used by radtest.
# Real Mikrotik NAS secrets are per-NAS, generated at onboarding (see scripts/add_nas.sh)
# and stored in the `nas` table — never reuse this value for a real tenant NAS.
RADIUS_SHARED_SECRET_DEFAULT=testing123
