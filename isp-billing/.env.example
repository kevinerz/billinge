MYSQL_HOST=192.168.38.3
MYSQL_PORT=3306
MYSQL_DATABASE=radius
MYSQL_USER=root
MYSQL_PASSWORD=change-me

# Kredensial gateway pembayaran MILIK PLATFORM SENDIRI (dipakai untuk
# platform_payments — menagih TENANT sewa SaaS). Kredensial gateway milik
# TENANT (untuk menagih pelanggan tenant itu sendiri) TIDAK di sini — itu
# disimpan per-tenant di tabel tenant_integrations, lewat API
# /api/tenant-integrations/.
PLATFORM_MIDTRANS_SERVER_KEY=change-me
PLATFORM_XENDIT_CALLBACK_TOKEN=change-me

# Broker & result backend buat billing engine (Celery + Redis) — lihat
# billing/tasks.py. Redis dipasang di VM yang sama dengan Django (localhost)
# untuk skala saat ini.
REDIS_URL=redis://localhost:6379/0

# --- VPN Hub / RouterOS API (CHR gateway) ---
# Dipakai backend untuk auto-daftar PPP secret+IP ke CHR saat NAS baru
# dibuat dengan opsi "konek lewat VPN Hub" (lihat nas/routeros.py +
# freeradius-isp/docs/mikrotik-vpn-hub.md). Kredensial ROUTEROS_* itu akun
# API di CHR-nya sendiri (buat di CHR: /user add name=... password=...
# group=full), BUKAN akun dashboard.
ROUTEROS_HOST=103.139.163.150
ROUTEROS_API_PORT=7652
ROUTEROS_USER=change-me
ROUTEROS_PASSWORD=change-me
ROUTEROS_USE_TLS=true
# CHR pakai cert self-signed di API-SSL secara default → verifikasi dimatikan.
# Nyalakan (true) hanya kalau CHR sudah dipasang cert yang tervalidasi.
ROUTEROS_TLS_VERIFY=false

# Nama PPP profile di CHR (dibuat oleh config/chr/setup_vpn_server.rsc).
VPN_PROFILE=billinge-vpn
# PSK IPsec bersama untuk opsi L2TP — HARUS sama persis dengan yang dipasang
# di setup_vpn_server.rsc (variabel ipsecPsk di script itu). Di-render ke
# dalam script client tenant oleh backend, tidak pernah dikirim mentah ke
# frontend.
VPN_IPSEC_PSK=change-me
# Dipakai saat me-render script client tenant.
VPN_HUB_PUBLIC_HOST=103.139.163.150
VPN_RADIUS_LAN=192.168.38.0/24
VPN_RADIUS_SERVER_IP=192.168.38.2
