MYSQL_HOST=192.168.38.3
MYSQL_PORT=3306
MYSQL_DATABASE=radius
MYSQL_USER=root
MYSQL_PASSWORD=change-me

# Kredensial gateway pembayaran MILIK PLATFORM SENDIRI (dipakai untuk
# platform_payments — menagih TENANT sewa SaaS). Kredensial gateway milik
# TENANT (untuk menagih pelanggan tenant itu sendiri) TIDAK di sini — itu
# disimpan per-tenant di tabel tenant_integrations, lewat API
# /api/tenant-integrations/.
PLATFORM_MIDTRANS_SERVER_KEY=change-me
PLATFORM_XENDIT_CALLBACK_TOKEN=change-me

# Broker & result backend buat billing engine (Celery + Redis) — lihat
# billing/tasks.py. Redis dipasang di VM yang sama dengan Django (localhost)
# untuk skala saat ini.
REDIS_URL=redis://localhost:6379/0
